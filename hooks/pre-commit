#!/bin/sh
# eMule-tooling editorconfig hook
repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 1
hook_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd) || exit 1
hook_runner="$hook_dir/../helpers/git_pre_commit_editorconfig.py"
if command -v python >/dev/null 2>&1; then
  exec python "$hook_runner" --repo-root "$repo_root"
fi
if command -v py >/dev/null 2>&1; then
  exec py -3 "$hook_runner" --repo-root "$repo_root"
fi
echo "Python 3 is required for the eMule-tooling editorconfig hook." >&2
exit 1
